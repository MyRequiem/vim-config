vim9script

###
# Настройки горячих клавиш, клавиатурных сочетаний и тайм-аутов.
# Name: mapping
#
# :options
# 18 mapping
###

# Снизить время ожидания завершения комбинации клавиш (маппинга). Делает
# отклик на нажатия моментальным, предотвращая "зависания" интерфейса.
# Name: timeoutlen (tm)
# Type: number
# Default: 1000
&timeoutlen = 500

# Время ожидания завершения системных кодов клавиш (например, стрелок или
# Esc). Значение '50' убирает микро-задержку при нажатии <Esc> для выхода из
# режима вставки.
# Name: ttimeoutlen (ttm)
# Type: number
# Default: -1 (значение копируется из timeoutlen)
&ttimeoutlen = 50
