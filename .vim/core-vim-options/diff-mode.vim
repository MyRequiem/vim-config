vim9script

###
# Настройки режима сравнения файлов (vimdiff).
# Name: diff-mode
#
# :options
# 17 diff mode
###

# Настройки режима сравнения файлов.
# Изменяет внешний вид и алгоритм поиска различий.
# Name: diffopt (dip)
# Type: string
# Default: "internal,filler,closeoff,indent-heuristic,inline:char"
#
# internal
#    Использует встроенный в Vim движок сравнения (работает быстрее внешних
#    утилит).
# filler
#    Вставляет пустые «виртуальные» строки, чтобы выравнивать текст в обоих
#    файлах друг напротив друга.
# vertical
#    Всегда открывает сравниваемые файлы в окнах рядом (вертикальный сплит).
# context:2
#    Показывает только по две неизмененные строки сверху и снизу от каждого
#    отличия (чтобы не листать лишний одинаковый текст).
&diffopt = 'internal,filler,vertical,context:2'
