vim9script

###
# Настройки визуального отображения текста на экране.
# Name: displaying-text
#
# :options
# 4 displaying text
###

# Отображать номера строк на левой панели.
# Name: number (nu)
# Type: boolean
# Default: false
&number = true

# Ширина колонки под номера строк (в символах).
# Позволяет зафиксировать ширину, чтобы экран не «дергался» при переходе на
# 5-значные номера строк.
# Name: numberwidth (nuw)
# Type: number
# Default: 4
&numberwidth = 7

# Минимальное количество строк, которые всегда видны сверху и снизу от курсора.
# Не дает курсору упираться в самый верхний или нижний край экрана при
# прокрутке.
# Name: scrolloff (so)
# Type: number
# Default: 0
&scrolloff = 3

# Минимальное количество символов, которые всегда видны справа и слева от
# курсора. Держит контекст длинной строки в поле зрения, когда отключен
# перенос строк (wrap).
# Name: sidescrolloff (siso)
# Type: number
# Default: 0
&sidescrolloff = 20

# Шаг горизонтальной прокрутки длинной строки при выходе курсора за границы
# экрана. Значение '1' обеспечивает максимально плавное смещение по одному
# символу за раз.
# Name: sidescroll (ss)
# Type: number
# Default: 0 (сдвиг сразу на половину экрана)
&sidescroll = 1

# Переносить длинные строки только на границах слов (чтобы слова не рвались
# посередине). Работает только при включенной опции 'wrap'.
# Name: linebreak (lbr)
# Type: boolean
# Default: false
&linebreak = true

# Сохранять исходный отступ (индексацию) для перенесенной части строки.
# Визуально выравнивает продолжение строки ровно под её началом.
# Name: breakindent (bri)
# Type: boolean
# Default: false
&breakindent = true

# Символы-маркеры, которые выводятся в начале каждой перенесенной строки.
# Помогают визуально отличить новую строку от продолжения старой.
# Name: showbreak (sbr)
# Type: string
# Default: ""
#
# Например:
#   |
#   |    Длинная строка ................
#   |    >> продолжение длинной строки
#   |
&showbreak = '>> '

# Настройка отображения «проблемных» строк и спецсимволов.
# Name: display (dy)
# Type: string
# Default: ""
#
# lastline
#    Если длинная строка не влезает в экран целиком, Vim покажет столько,
#    сколько поместилось, а в конце строки выведет '@@@'.
# truncate
#    Как lastline, только '@@@' отображается в начале последней строки.
# uhex
#    Отображает непечатаемые символы в шестнадцатеричном формате (например,
#    <0d> вместо ^M).
&display = 'truncate'

# Список невидимых символов (отображаются только при включенной опции 'list').
# Помогает контролировать скрытые пробелы, табы, переносы в коде и др.
# Name: listchars (lcs)
# Type: string
# Default: "eol:$"
#
# eol
#    Конец строки.
# space
#    Обычные пробелы.
# nbsp
#    Неразрывный пробел (Non-Breaking Space: &nbsp; или U+00A0) (часто
#    копируется из браузеров или документации). Внешне выглядит как пробел, но
#    компиляторы и интерпретаторы ломаются об него с критическими ошибками.
#    Например, строка: 'В моем конфиге Vim уже больше 20 лет нет мусора.'
# trail
#    Лишние пробелы в самом конце строки (trailing spaces).
# tab
#    Символы табуляции (задаются двумя знаками: первый выводится один раз в
#    начале, второй заполняет оставшееся пространство таба).
# extends / precedes
#    Символы-указатели на то, что строка продолжается вправо или влево за
#    границы экрана (актуально, если отключен перенос строк 'nowrap').
&listchars = 'eol:↵,'
          .. 'space:·,'
          .. 'nbsp:⍽,'
          .. 'trail:•,'
          .. 'tab:T›,'
          .. 'extends:»,'
          .. 'precedes:«'
